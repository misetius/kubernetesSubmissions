<!-- index.html -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Todoapp</title>
</head>
<body>
    <h1>Todoapp</h1>
    <% if (data) { %>
        
        <img src="<%= data %>"">
 <% } %>
    
<form id="oma">
  <input type="text" id="todo" name="todo"  maxlength="140"><br>
  <input type="submit" value="Submit">
</form>

<h2>Not done</h2>
            <ul>
                <% todos.forEach(item=> { %>
                    <li>
                    <h3 id='<%= item %>'>   <%= item.todo %> </h3> 
                    <button onclick="done(<%= item.id %>)">Mark as done</button>
                    </li>
                    <% }); %>
            </ul>

<h2>Done</h2>
            <ul>
                <% donetodos.forEach(item=> { %>
                    <li>
                    <h3 id='<%= item %>'>   <%= item.todo %> </h3> 
                    </li>
                    <% }); %>
            </ul>


<p>Devops width Kubernetes 2025 (test for argo)</p>

<script>
    
    var url = '<%= backendurl %>';

    const form = document.querySelector('#oma');

    form.addEventListener('submit', event => {
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(data)
        });
    })

    async function done(id) {
        const url2 = url + "/" + id
        try {
            const response = await fetch(url2, {
                method: 'PUT'
            });
        } catch (err){
            console.log(err);
        }
        location.reload()
    }





</script>
</body>
</html>